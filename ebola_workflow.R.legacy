#' =============================================================================
#' Ebola Outbreak Simulation and Analysis Workflow
#' =============================================================================
#'
#' Complete end-to-end demonstration of the Epiverse-TRACE pipeline for
#' outbreak analysis, from simulation to publication-ready visualizations.
#'
#' Pipeline Stages:
#'   1. Simulation    - Generate synthetic outbreak data (simulist)
#'   2. Data Cleaning - Standardize and validate data (cleanepi, linelist)
#'   3. Analysis      - Estimate case fatality risk (cfr)
#'   4. Visualization - Create epidemic curves and plots (ggplot2, tracetheme)
#'
#' @author Epiverse-TRACE Team
#' @version 2.0.0
#' @date 2024-01-01
#'
#' =============================================================================

# --- Environment Setup ---

message("Starting Ebola outbreak analysis workflow...")
message("R version: ", R.version.string)

# Check R version
if (getRversion() < "4.3.0") {
  warning("This workflow was designed for R >= 4.3.0. You have ", R.version.string)
}

# Configure repositories
options(repos = c(
  epiverse = "https://epiverse-trace.r-universe.dev",
  CRAN = "https://cloud.r-project.org"
))

# Install and load package manager
if (!require("pacman", quietly = TRUE)) {
  message("Installing pacman package manager...")
  install.packages("pacman")
}

# Load required packages with error handling
message("Loading required packages...")
tryCatch(
  {
    pacman::p_load(
      simulist,       # Outbreak simulation
      cleanepi,       # Data cleaning
      linelist,       # Line list tagging
      cfr,            # Case fatality risk estimation
      epiparameter,   # Epidemiological parameters
      tidyverse,      # Data manipulation
      here,           # Portable file paths
      qs,             # Fast serialization
      ggplot2,        # Visualization
      tracetheme      # Epiverse theme
    )
    message("All packages loaded successfully")
  },
  error = function(e) {
    stop("Failed to load packages. Error: ", e$message,
         "\nTry running: install.packages('pacman')")
  }
)

# Create directory structure
message("Setting up directory structure...")
dirs <- c(
  here::here("data", "raw"),
  here::here("data", "processed"),
  here::here("outputs", "plots"),
  here::here("outputs", "tables")
)

for (dir in dirs) {
  dir.create(dir, recursive = TRUE, showWarnings = FALSE)
}

# --- Function Definitions ---

#' Setup Ebola Epidemiological Parameters
#'
#' Creates epiparameter objects for Ebola virus disease based on
#' literature values. Parameters include contact distribution,
#' infectious period, incubation period, and delay distributions.
#'
#' @return Named list of epiparameter objects
#'
#' @examples
#' params <- setup_ebola_parameters()
#' params$contact_distribution
setup_ebola_parameters <- function() {
  message("Setting up epidemiological parameters...")

  # Contact distribution - Poisson with mean R0 ~ 2
  # Assumption: Basic reproduction number for Ebola is approximately 2
  contact_distribution <- epiparameter::epiparameter(
    disease = "Ebola Virus Disease",
    epi_name = "contact distribution",
    prob_distribution = create_prob_distribution(
      prob_distribution = "pois",
      prob_distribution_params = c(mean = 2)
    )
  )

  # Infectious period - Gamma distributed, mean ~ 6 days
  # Source: WHO Ebola response reports
  infectious_period <- epiparameter::epiparameter(
    disease = "Ebola Virus Disease",
    epi_name = "infectious period",
    prob_distribution = create_prob_distribution(
      prob_distribution = "gamma",
      prob_distribution_params = c(shape = 2, scale = 3)
    )
  )

  # Incubation period - Gamma distributed, mean ~ 10 days
  # Source: Systematic reviews of Ebola outbreaks
  incubation_period <- epiparameter::epiparameter(
    disease = "Ebola Virus Disease",
    epi_name = "incubation period",
    prob_distribution = create_prob_distribution(
      prob_distribution = "gamma",
      prob_distribution_params = c(shape = 2, scale = 5)
    )
  )

  # Onset to hospitalization delay - mean ~ 4 days
  onset_to_hosp <- epiparameter::epiparameter(
    disease = "Ebola Virus Disease",
    epi_name = "onset to hospitalisation",
    prob_distribution = create_prob_distribution(
      prob_distribution = "gamma",
      prob_distribution_params = c(shape = 2, scale = 2)
    )
  )

  # Onset to death delay - Based on Barry et al. 2018
  # Used for CFR delay correction
  onset_to_death <- epiparameter::epiparameter(
    disease = "Ebola Virus Disease",
    epi_name = "onset to death",
    prob_distribution = create_prob_distribution(
      prob_distribution = "gamma",
      prob_distribution_params = c(shape = 2.4, scale = 3.33)
    )
  )

  message("Parameters configured")

  list(
    contact_distribution = contact_distribution,
    infectious_period = infectious_period,
    incubation_period = incubation_period,
    onset_to_hosp = onset_to_hosp,
    onset_to_death = onset_to_death
  )
}

#' Simulate Ebola Outbreak
#'
#' Generates synthetic outbreak data using a branching process model
#' with realistic epidemiological parameters.
#'
#' @param params List of epiparameter objects from setup_ebola_parameters()
#' @param outbreak_size Numeric vector c(min, max) for outbreak size
#' @param start_date Date object for outbreak start
#' @param seed Random seed for reproducibility
#'
#' @return List containing linelist and contacts data frames
#'
#' @examples
#' params <- setup_ebola_parameters()
#' outbreak <- simulate_ebola_outbreak(params, outbreak_size = c(100, 500))
simulate_ebola_outbreak <- function(params,
                                   outbreak_size = c(100, 500),
                                   start_date = as.Date("2024-01-01"),
                                   seed = 42) {
  message("Simulating outbreak with parameters:")
  message("  - Outbreak size range: ", outbreak_size[1], "-", outbreak_size[2])
  message("  - Start date: ", start_date)
  message("  - Random seed: ", seed)

  set.seed(seed)

  tryCatch(
    {
      outbreak <- simulist::sim_outbreak(
        contact_distribution = params$contact_distribution,
        infectious_period = params$infectious_period,
        prob_infection = 0.6,  # High transmission probability given contact
        onset_to_hosp = params$onset_to_hosp,
        onset_to_death = params$onset_to_death,
        outbreak_size = outbreak_size,
        outbreak_start_date = start_date
      )

      message("Simulation complete:")
      message("  - Cases generated: ", nrow(outbreak$linelist))
      message("  - Contacts recorded: ", nrow(outbreak$contacts))

      outbreak
    },
    error = function(e) {
      stop("Simulation failed: ", e$message)
    }
  )
}

#' Clean and Tag Outbreak Data
#'
#' Performs data cleaning and applies linelist tags for downstream analysis.
#' Includes validation checks and data quality reporting.
#'
#' @param linelist Data frame with raw outbreak data
#'
#' @return Tagged linelist object
#'
#' @examples
#' cleaned <- clean_outbreak_data(outbreak$linelist)
clean_outbreak_data <- function(linelist) {
  message("Cleaning outbreak data...")
  message("  - Input rows: ", nrow(linelist))

  # Check for required columns
  required_cols <- c("id", "date_onset", "date_reporting", "outcome")
  missing_cols <- setdiff(required_cols, colnames(linelist))
  if (length(missing_cols) > 0) {
    warning("Missing columns: ", paste(missing_cols, collapse = ", "))
  }

  # Clean with cleanepi
  tryCatch(
    {
      cleaned_linelist <- cleanepi::clean_data(
        data = linelist,
        standardize_column_names = list(keep = NULL),
        replace_missing_values = list(
          target_columns = NULL,
          na_strings = c("", "NA", "unknown")
        )
      )

      message("  - After cleaning: ", nrow(cleaned_linelist), " rows")

      # Tag with linelist package
      tagged_linelist <- cleaned_linelist |>
        linelist::make_linelist(
          id = "id",
          date_onset = "date_onset",
          date_reporting = "date_reporting",
          date_admission = "date_admission",
          date_outcome = "date_outcome",
          outcome = "outcome",
          gender = "sex",
          age = "age"
        )

      # Validate tags
      linelist::validate_linelist(tagged_linelist)
      message("Data cleaning and tagging successful")

      tagged_linelist
    },
    error = function(e) {
      stop("Data cleaning failed: ", e$message)
    }
  )
}

#' Estimate Case Fatality Risk
#'
#' Calculates static and rolling CFR estimates with delay correction.
#'
#' @param tagged_linelist Tagged linelist from clean_outbreak_data()
#' @param onset_to_death_params Parameters for delay distribution
#'
#' @return List with static and rolling CFR estimates
#'
#' @examples
#' cfr_results <- estimate_cfr(tagged_linelist, params$onset_to_death)
estimate_cfr <- function(tagged_linelist, onset_to_death_params) {
  message("Estimating case fatality risk...")

  # Prepare data for CFR analysis
  # Aggregate cases by date
  cases_df <- tagged_linelist |>
    as_tibble() |>
    group_by(date = date_onset) |>
    summarise(cases = n(), .groups = "drop") |>
    filter(!is.na(date))

  # Aggregate deaths by date
  deaths_df <- tagged_linelist |>
    as_tibble() |>
    filter(outcome == "died") |>
    group_by(date = date_outcome) |>
    summarise(deaths = n(), .groups = "drop") |>
    filter(!is.na(date))

  # Merge and fill gaps
  cfr_data <- full_join(cases_df, deaths_df, by = "date") |>
    arrange(date) |>
    mutate(
      cases = replace_na(cases, 0),
      deaths = replace_na(deaths, 0)
    )

  # Fill missing dates with zeros
  all_dates <- seq(min(cfr_data$date), max(cfr_data$date), by = "day")
  cfr_data <- tibble(date = all_dates) |>
    left_join(cfr_data, by = "date") |>
    mutate(
      cases = replace_na(cases, 0),
      deaths = replace_na(deaths, 0)
    )

  message("  - Date range: ", min(cfr_data$date), " to ", max(cfr_data$date))
  message("  - Total cases: ", sum(cfr_data$cases))
  message("  - Total deaths: ", sum(cfr_data$deaths))

  # Define delay distribution function
  # Extract parameters from epiparameter object
  delay_func <- function(x) dgamma(x, shape = 2.40, scale = 3.33)

  # Static CFR
  message("Computing static CFR...")
  cfr_static_est <- cfr::cfr_static(
    data = cfr_data,
    delay_density = delay_func
  )

  message("Static CFR estimate:")
  print(cfr_static_est)

  # Rolling CFR
  message("Computing rolling CFR...")
  cfr_rolling_est <- cfr::cfr_rolling(
    data = cfr_data,
    delay_density = delay_func
  )

  message("CFR estimation complete")

  list(
    static = cfr_static_est,
    rolling = cfr_rolling_est,
    data = cfr_data
  )
}

#' Create Outbreak Visualizations
#'
#' Generates epidemic curve and rolling CFR plots using tracetheme.
#'
#' @param tagged_linelist Tagged linelist data
#' @param cfr_rolling Rolling CFR estimates
#'
#' @return List of ggplot objects
#'
#' @examples
#' plots <- create_visualizations(tagged_linelist, cfr_results$rolling)
create_visualizations <- function(tagged_linelist, cfr_rolling) {
  message("Creating visualizations...")

  # Epidemic curve
  epicurve_plot <- tagged_linelist |>
    as_tibble() |>
    ggplot(aes(x = date_onset)) +
    geom_histogram(binwidth = 7, fill = "steelblue", color = "white") +
    labs(
      title = "Epidemic Curve of Simulated Ebola Outbreak",
      subtitle = "Weekly case counts by date of symptom onset",
      x = "Date of Onset",
      y = "Weekly Cases"
    ) +
    tracetheme::theme_trace()

  # Rolling CFR plot
  cfr_plot <- cfr_rolling |>
    ggplot(aes(x = date)) +
    geom_line(aes(y = severity_estimate), color = "darkred", linewidth = 1) +
    geom_ribbon(
      aes(ymin = severity_low, ymax = severity_high),
      fill = "darkred", alpha = 0.2
    ) +
    labs(
      title = "Rolling Case Fatality Risk (CFR) Estimates",
      subtitle = "Delay-corrected estimates with 95% confidence interval",
      x = "Date",
      y = "CFR Estimate",
      caption = "Shaded area represents 95% confidence interval"
    ) +
    scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
    tracetheme::theme_trace()

  message("Visualizations created")

  list(
    epicurve = epicurve_plot,
    cfr = cfr_plot
  )
}

#' Save Workflow Outputs
#'
#' Saves all generated data and plots to appropriate directories.
#'
#' @param outbreak Simulated outbreak data
#' @param tagged_linelist Cleaned and tagged data
#' @param cfr_results CFR estimation results
#' @param plots Visualization objects
#'
#' @examples
#' save_outputs(outbreak, tagged_linelist, cfr_results, plots)
save_outputs <- function(outbreak, tagged_linelist, cfr_results, plots) {
  message("Saving outputs...")

  # Save raw data
  qs::qsave(outbreak$linelist, here::here("data", "raw", "simulated_linelist.qs"))
  qs::qsave(outbreak$contacts, here::here("data", "raw", "simulated_contacts.qs"))
  message("  - Raw data saved to data/raw/")

  # Save processed data
  qs::qsave(tagged_linelist, here::here("data", "processed", "cleaned_tagged_linelist.qs"))
  message("  - Processed data saved to data/processed/")

  # Save CFR tables
  readr::write_csv(
    cfr_results$rolling,
    here::here("outputs", "tables", "cfr_rolling_estimates.csv")
  )
  message("  - Tables saved to outputs/tables/")

  # Save plots
  ggsave(
    here::here("outputs", "plots", "epicurve.png"),
    plot = plots$epicurve,
    width = 8, height = 5, dpi = 300, bg = "white"
  )

  ggsave(
    here::here("outputs", "plots", "cfr_rolling.png"),
    plot = plots$cfr,
    width = 8, height = 5, dpi = 300, bg = "white"
  )
  message("  - Plots saved to outputs/plots/")

  message("All outputs saved successfully")
}

# --- Main Workflow Execution ---

#' Run Complete Ebola Workflow
#'
#' Orchestrates the entire analysis pipeline from simulation to visualization.
#'
#' @export
#' @examples
#' run_ebola_workflow()
run_ebola_workflow <- function() {
  start_time <- Sys.time()
  message("\n", rep("=", 70))
  message("EBOLA OUTBREAK ANALYSIS WORKFLOW")
  message(rep("=", 70), "\n")

  tryCatch(
    {
      # Stage 1: Setup parameters
      message("[1/5] Setting up parameters...")
      params <- setup_ebola_parameters()

      # Stage 2: Simulate outbreak
      message("\n[2/5] Simulating outbreak...")
      outbreak <- simulate_ebola_outbreak(
        params = params,
        outbreak_size = c(100, 500),
        start_date = as.Date("2024-01-01"),
        seed = 42
      )

      # Stage 3: Clean data
      message("\n[3/5] Cleaning data...")
      tagged_linelist <- clean_outbreak_data(outbreak$linelist)

      # Stage 4: Analyze CFR
      message("\n[4/5] Analyzing case fatality risk...")
      cfr_results <- estimate_cfr(tagged_linelist, params$onset_to_death)

      # Stage 5: Create visualizations
      message("\n[5/5] Creating visualizations...")
      plots <- create_visualizations(tagged_linelist, cfr_results$rolling)

      # Save all outputs
      message("\n[Final] Saving outputs...")
      save_outputs(outbreak, tagged_linelist, cfr_results, plots)

      # Summary
      end_time <- Sys.time()
      duration <- round(as.numeric(difftime(end_time, start_time, units = "secs")), 1)

      message("\n", rep("=", 70))
      message("WORKFLOW COMPLETE")
      message(rep("=", 70))
      message("Duration: ", duration, " seconds")
      message("Outputs saved to: ", here::here("outputs"))
      message("\nCheck the following files:")
      message("  - Epidemic curve: outputs/plots/epicurve.png")
      message("  - CFR plot: outputs/plots/cfr_rolling.png")
      message("  - CFR table: outputs/tables/cfr_rolling_estimates.csv")
      message(rep("=", 70), "\n")

      invisible(list(
        outbreak = outbreak,
        tagged_linelist = tagged_linelist,
        cfr_results = cfr_results,
        plots = plots
      ))
    },
    error = function(e) {
      message("\n", rep("!", 70))
      message("WORKFLOW FAILED")
      message(rep("!", 70))
      message("Error: ", e$message)
      message("\nPlease check:")
      message("  1. All required packages are installed")
      message("  2. You have write permissions to the outputs directory")
      message("  3. Your R version is >= 4.3.0")
      message(rep("!", 70), "\n")
      stop(e)
    }
  )
}

# Execute the workflow
run_ebola_workflow()
